term = xterm-256color
theme = "Atom One Dark"
background= #1e222a

macos-icon = xray
macos-titlebar-style = tabs

font-family = "MonacoLigaturized Nerd Font Mono"
font-thicken = true
font-size = 14
adjust-cell-height = 2

mouse-hide-while-typing = true

window-decoration = false
window-save-state = always

background-opacity = 1
background-blur-radius = 20

# keybinds
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right

keybind = cmd+h=previous_tab
keybind = cmd+l=next_tab

keybind = super+ctrl+h=resize_split:left,10
keybind = super+ctrl+j=resize_split:down,10
keybind = super+ctrl+k=resize_split:up,10
keybind = super+ctrl+l=resize_split:right,10
keybind = shift+enter=text:\n


