# Reload yabai
ctrl + alt + cmd - r : launchctl kickstart -k "gui/${UID}/homebrew.mxcl.yabai"
# Application Shortcuts
ctrl + fn - f : open ~
ctrl + fn - t : open -na /Applications/Alacritty.app
ctrl + fn - s : open "x-apple.systempreferences:"
ctrl + fn - a : open -a "About This Mac"
ctrl + fn - c : open -na /Applications/Google\ Chrome.app
ctrl + fn - l : open -na /Applications/Slack.app
ctrl + fn - m : open -na /System/Applications/Music.app

ctrl + shift - space : yabai -m space --layout "$(yabai -m query --spaces --space | jq -r 'if .type == "bsp" then "stack" else "bsp" end')"


# focus window
alt - j : yabai -m window --focus west
alt - k : yabai -m window --focus south
alt - i : yabai -m window --focus north
alt - l : yabai -m window --focus east

# swap managed window
shift + alt - i : yabai -m window --swap north
shift + alt - k : yabai -m window --swap south
shift + alt - j : yabai -m window --swap west
shift + alt - l : yabai -m window --swap east
# move managed window
shift + cmd - j : yabai -m window --warp west
shift + cmd - i : yabai -m window --wrap north
shift + cmd - k : yabai -m window --wrap south
shift + cmd - l : yabai -m window --wrap east
# balance size of windows
shift + alt - 0 : yabai -m space --balance
# move window to workspace
shift + alt - 1: yabai -m window --space 1 --focus; yabai -m space --focus 1
shift + alt - 2: yabai -m window --space 2 --focus; yabai -m space --focus 2
shift + alt - 3: yabai -m window --space 3 --focus; yabai -m space --focus 3
shift + alt - 4: yabai -m window --space 4 --focus; yabai -m space --focus 4
shift + alt - 5: yabai -m window --space 5 --focus; yabai -m space --focus 5
shift + alt - 6: yabai -m window --space 6 --focus; yabai -m space --focus 6
shift + alt - 7: yabai -m window --space 7 --focus; yabai -m space --focus 7
# focus monitor
ctrl + alt - z : yabai -m display --focus next
ctrl + alt - x : yabai -m display --focus prev
ctrl + alt - 1 : yabai -m display --focus 1
ctrl + alt - 2 : yabai -m display --focus 2
ctrl + alt - 3 : yabai -m display --focus 3
ctrl + alt - 4 : yabai -m display --focus 4

:: resize : echo "resize mode on"; borders active_color=0xffff0000
:: default : echo "resize mode off"; borders active_color=0xff7aa2f7

# Enter / exit
default < cmd + ctrl + shift - r ; resize
resize < escape  ; default
resize < q       ; default
# same key toggles back out
resize < cmd - r ; default

# hjkl resize (stay in mode while pressing)
resize < h : yabai -m window --resize right:-50:0 || yabai -m window --resize left:-50:0
resize < l : yabai -m window --resize right:50:0  || yabai -m window --resize left:50:0
resize < j : yabai -m window --resize bottom:0:50 || yabai -m window --resize top:0:50
resize < k : yabai -m window --resize bottom:0:-50 || yabai -m window --resize top:0:-50

# bigger steps with shift
resize < shift - h : yabai -m window --resize right:-150:0 || yabai -m window --resize left:-150:0
resize < shift - l : yabai -m window --resize right:150:0  || yabai -m window --resize left:150:0
resize < shift - j : yabai -m window --resize bottom:0:150 || yabai -m window --resize top:0:150
resize < shift - k : yabai -m window --resize bottom:0:-150 || yabai -m window --resize top:0:-150

# re-balance all windows to equal size
resize < 0 : yabai -m space --balance
# toggle window split type
alt - e : yabai -m window --toggle split

# float / unfloat window and center on screen
alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2
# grow floating window
alt - up : yabai -m window --resize top_left:-50:-50; yabai -m window --resize bottom_right:50:50
# shrink floating window
alt - down : yabai -m window --resize top_left:50:50; yabai -m window --resize bottom_right:-50:-50


# Toggle Slack: hide if it's frontmost, otherwise bring it forward
cmd + shift - s : ~/.config/skhd/toggle-app.sh "Slack"

